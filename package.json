{
  "name": "@typescript-cli-template/root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run -r build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "pnpm -r --filter=!browser --filter=!@in-the-black/accounts-api --filter=!@in-the-black/currencies-api --filter=!@in-the-black/query-language-knex t",
    "test:all": "pnpm -r --filter=!browser t",
    "test:browser": "pnpm -r --filter=browser t",
    "release": "pnpm build && pnpm changeset publish",
    "prepare": "husky || echo 1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "author": "Peter Kinnaird <peter@kinnaird.scot>",
  "license": "ISC",
  "description": "A simple Typescript example project",
  "packageManager": "pnpm@10.15.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.7.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sqlite3",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "unrs-resolver"
    ],
    "overrides": {
      "axios": ">=1.12.0",
      "devalue": ">=5.6.2",
      "glob": ">=11.1.0",
      "h3": ">=1.15.5",
      "node-forge": ">=1.3.2",
      "qs": ">=6.14.1",
      "tar@<7.5.7": ">=7.5.7",
      "tar-fs@<2.1.4": ">=2.1.4",
      "esbuild@<=0.24.2": ">=0.25.0",
      "lodash-es@>=4.0.0 <=4.17.22": ">=4.17.23",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "hono@<4.11.7": ">=4.11.7",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "@modelcontextprotocol/sdk@>=1.10.0 <=1.25.3": ">=1.26.0",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1"
    }
  }
}
