{
  "name": "@watcher/root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run -r --sequential build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "pnpm -r t",
    "release": "pnpm build && pnpm changeset publish",
    "prepare": "husky || echo 1"
  },
  "author": "Peter Kinnaird <peter@kinnaird.scot>",
  "license": "ISC",
  "description": "The Watcher — property listing monitor",
  "packageManager": "pnpm@10.15.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.7.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sqlite3"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23"
    }
  }
}
