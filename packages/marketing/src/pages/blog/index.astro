---
import BaseLayout from '../../layouts/base.astro'
import Nav from '../../components/nav.astro'
import Footer from '../../components/footer.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout title="Blog — In The Black" description="News, updates, and guides from the In The Black team.">
  <Nav />
  <main id="main-content" class="mx-auto max-w-4xl px-6 pt-32 pb-20">
    <header class="mb-12">
      <h1 class="font-serif text-4xl font-bold text-white md:text-5xl">Blog</h1>
      <p class="mt-4 text-lg text-slate-light">News, updates, and guides from the team.</p>
    </header>

    {posts.length === 0 && (
      <p class="text-slate-mid">No posts yet. Check back soon.</p>
    )}

    <div class="grid gap-8">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="group rounded-2xl border border-slate-dark/50 bg-deep-navy p-6 transition-all hover:border-emerald/30 hover:shadow-lg hover:shadow-emerald/5 md:p-8">
          <article>
            <time datetime={post.data.date.toISOString()} class="text-sm text-slate-mid">
              {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="mt-2 text-xl font-semibold text-white transition-colors group-hover:text-emerald md:text-2xl">
              {post.data.title}
            </h2>
            <p class="mt-3 text-slate-light">{post.data.description}</p>
            {post.data.tags && (
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <span class="rounded-full bg-slate-dark/60 px-3 py-1 text-xs text-slate-light">{tag}</span>
                ))}
              </div>
            )}
          </article>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
