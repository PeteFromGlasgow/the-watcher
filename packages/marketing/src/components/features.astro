---
const features = [
  {
    icon: '&#x2261;',
    title: 'Zero-Sum Methodology',
    description: 'Give every pound a job. Assign £50 to your running-shoe fund, £30 to guitar strings, and £200 to rent — until the unassigned balance hits zero. Nothing slips through the cracks.'
  },
  {
    icon: '&#x25A0;',
    title: 'Double-Entry Bookkeeping',
    description: 'Bank-grade accuracy with debits and credits that always balance. Every transaction is split and verified down to the penny.'
  },
  {
    icon: '&#x2B21;',
    title: 'Nested Pots',
    description: 'Organize with unlimited depth. Create Hobbies > Photography > Lenses or Expenses > Food > Eating Out > Work Lunches. Assign money at any level and watch balances roll up to the parent.'
  },
  {
    icon: '&#x2696;',
    title: 'Clearing House',
    description: 'Match pending bank transactions against receipts and notes before they finalize. Perfect reconciliation, every time.'
  },
  {
    icon: '&#x2737;',
    title: 'Key:Value Labels',
    description: 'Tag transactions with flexible labels like hobby:woodworking, trip:paris-2025, or tax:deductible. Filter across pots to answer questions like "how much did I spend on photography this year?" in seconds.'
  },
  {
    icon: '&#x29C9;',
    title: 'Spreadsheet-Speed UI',
    description: 'A data-dense, keyboard-driven interface built for people who think in rows and columns. No clicks wasted.'
  }
]
---

<section id="features" class="border-t border-slate-dark/50 py-20 md:py-28" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center" data-reveal>
      <h2 id="features-heading" class="mb-4 font-serif text-3xl font-bold text-white md:text-4xl">Built for precision</h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-light">
        Every feature designed for people who take their finances seriously.
        Open-source core. No compromises.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-stagger data-reveal>
      {features.map(feature => (
        <div class="hover-lift group rounded-xl border border-slate-dark/50 bg-deep-navy/50 p-6 transition-all hover:border-slate-mid/50 hover:bg-deep-navy">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-emerald/10 text-lg text-emerald transition-transform duration-300 group-hover:scale-110" aria-hidden="true" set:html={feature.icon} />
          <h3 class="mb-2 text-lg font-semibold text-white">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-slate-light">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
