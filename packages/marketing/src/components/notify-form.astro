---
const CONSENT_TEXT = 'I agree to receive product launch and update emails from In The Black. I understand I can unsubscribe at any time.'
const API_URL = import.meta.env.PUBLIC_API_URL || '/api'
---

<section id="notify" class="border-t border-slate-dark/50 py-20 md:py-28" aria-labelledby="notify-heading">
  <div class="mx-auto max-w-2xl px-6 text-center">
    <div data-reveal>
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-emerald/20 bg-emerald/10 px-4 py-1.5 text-sm text-emerald-light">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-light" aria-hidden="true"></span>
        Coming Soon
      </div>
      <h2 id="notify-heading" class="mb-4 font-serif text-3xl font-bold text-white md:text-4xl">Be the first to know</h2>
      <p class="mx-auto mb-8 max-w-lg text-lg text-slate-light">
        We're building something special. Sign up to get notified when we launch.
      </p>
    </div>

    <form id="notify-form" data-reveal data-delay="200" class="mx-auto max-w-md" aria-label="Launch notification signup">
      <div class="flex flex-col gap-3 sm:flex-row">
        <div class="flex-1">
          <label for="notify-email" class="sr-only">Email address</label>
          <input
            id="notify-email"
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
            class="w-full rounded-lg border border-slate-dark bg-deep-navy px-4 py-3 text-sm text-white placeholder-slate-mid outline-none transition-colors focus:border-emerald/50 focus:ring-1 focus:ring-emerald/50"
          />
        </div>
        <button
          type="submit"
          class="hover-lift rounded-lg bg-emerald px-6 py-3 text-sm font-semibold text-midnight shadow-lg shadow-emerald/20 transition-all hover:bg-emerald-light hover:shadow-emerald/30 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-emerald disabled:shadow-none"
        >
          Notify Me
        </button>
      </div>

      <!-- GDPR consent checkbox -->
      <label for="notify-consent" class="mt-4 flex items-start gap-3 text-left cursor-pointer">
        <input
          id="notify-consent"
          type="checkbox"
          name="consent"
          required
          class="mt-0.5 h-4 w-4 shrink-0 appearance-none rounded border border-slate-dark bg-deep-navy checked:border-emerald checked:bg-emerald"
        />
        <span class="text-xs leading-relaxed text-slate-mid">
          {CONSENT_TEXT}
        </span>
      </label>

      <!-- Status messages (aria-live for screen reader announcements) -->
      <div id="notify-success" class="mt-4 hidden rounded-lg border border-emerald/20 bg-emerald/5 p-3 text-sm text-emerald-light" role="status" aria-live="polite">
        You're on the list! We'll email you when we launch.
      </div>
      <div id="notify-error" class="mt-4 hidden rounded-lg border border-rose/20 bg-rose/5 p-3 text-sm text-rose" role="alert" aria-live="assertive">
      </div>

      <p class="mt-4 text-xs text-slate-mid">
        We respect your privacy. No spam, ever. Unsubscribe with one click.
        See our <a href="#" class="underline transition-colors hover:text-white">privacy policy</a>.
      </p>
    </form>
  </div>
</section>

<script define:vars={{ API_URL, CONSENT_TEXT }} is:inline>
  function initNotifyForm() {
    const form = document.getElementById('notify-form')
    if (!form) return

    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      const formEl = e.target
      const email = formEl.querySelector('[name="email"]').value
      const consent = formEl.querySelector('[name="consent"]').checked
      const button = formEl.querySelector('button[type="submit"]')
      const successEl = document.getElementById('notify-success')
      const errorEl = document.getElementById('notify-error')

      // Reset status
      successEl.classList.add('hidden')
      errorEl.classList.add('hidden')

      if (!consent) {
        errorEl.textContent = 'Please agree to receive emails to continue.'
        errorEl.classList.remove('hidden')
        return
      }

      button.disabled = true
      button.setAttribute('aria-busy', 'true')
      button.textContent = 'Submitting...'

      try {
        const response = await fetch(API_URL + '/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            marketing_consent: consent,
            consent_text: CONSENT_TEXT
          })
        })

        const data = await response.json()

        if (response.ok) {
          successEl.classList.remove('hidden')
          formEl.querySelector('[name="email"]').value = ''
          formEl.querySelector('[name="consent"]').checked = false
        } else {
          errorEl.textContent = data.error || 'Something went wrong. Please try again.'
          errorEl.classList.remove('hidden')
        }
      } catch (_err) {
        errorEl.textContent = 'Could not connect to the server. Please try again later.'
        errorEl.classList.remove('hidden')
      } finally {
        button.disabled = false
        button.removeAttribute('aria-busy')
        button.textContent = 'Notify Me'
      }
    })
  }

  initNotifyForm()
  document.addEventListener('astro:after-swap', initNotifyForm)
</script>
