---
import MoneyFlowBg from './money-flow-bg.astro'
---

<section class="relative overflow-hidden pb-20 pt-32 md:pb-32 md:pt-44" aria-label="Introduction">
  <!-- 3D money-flow canvas background -->
  <MoneyFlowBg />

  <!-- Animated background glows -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-emerald/5 blur-3xl animate-pulse-glow"></div>
    <div class="absolute -left-40 top-40 h-[400px] w-[400px] rounded-full bg-violet/3 blur-3xl animate-pulse-glow" style="animation-delay: 1.5s;"></div>
    <div class="absolute -right-40 top-60 h-[300px] w-[300px] rounded-full bg-gold/3 blur-3xl animate-pulse-glow" style="animation-delay: 3s;"></div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <!-- Badge -->
    <div data-reveal="fade-in" class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald/20 bg-emerald/10 px-4 py-1.5 text-sm text-emerald-light">
      <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-light" aria-hidden="true"></span>
      Open Source &middot; Self-Hostable &middot; Pro Features Available
    </div>

    <!-- Heading -->
    <h1 data-reveal data-delay="100" class="mb-6 font-serif text-4xl font-bold leading-tight text-white md:text-6xl lg:text-7xl">
      Your money.<br/>
      <span class="text-emerald">Accounted for.</span>
    </h1>

    <!-- Subheading -->
    <p data-reveal data-delay="200" class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-slate-light md:text-xl">
      Zero-sum budgeting built for power users. Double-entry precision, spreadsheet-speed UI,
      and pro-grade bank sync &mdash; all in an open-source package you can self-host.
    </p>

    <!-- CTA buttons -->
    <div data-reveal data-delay="350" class="flex flex-col items-center justify-center gap-4 sm:flex-row" role="group" aria-label="Call to action">
      <a href="#pricing" class="hover-lift rounded-lg bg-emerald px-8 py-3 text-base font-semibold text-midnight shadow-lg shadow-emerald/20 transition-all hover:bg-emerald-light hover:shadow-emerald/30">
        Start Free
      </a>
      <a href="#open-source" class="rounded-lg border border-slate-dark px-8 py-3 text-base font-semibold text-white transition-colors hover:border-slate-mid hover:bg-deep-navy">
        View on GitHub
      </a>
    </div>

    <!-- Floating mini-dashboard hint -->
    <div data-reveal="fade-in" data-delay="600" class="mx-auto mt-16 max-w-lg" aria-hidden="true">
      <div class="animate-float rounded-xl border border-slate-dark/50 bg-deep-navy/80 p-4 shadow-2xl shadow-midnight/50 backdrop-blur-sm">
        <div class="mb-3 flex items-center gap-2 text-xs text-slate-mid">
          <span class="h-2 w-2 rounded-full bg-emerald"></span>
          Budget: January 2026
        </div>
        <div class="grid grid-cols-3 gap-3 text-center">
          <div>
            <div class="font-mono text-lg font-bold text-emerald">&pound;2,400</div>
            <div class="text-xs text-slate-mid">Income</div>
          </div>
          <div>
            <div class="font-mono text-lg font-bold text-gold">&pound;1,850</div>
            <div class="text-xs text-slate-mid">Assigned</div>
          </div>
          <div>
            <div class="font-mono text-lg font-bold text-violet">&pound;550</div>
            <div class="text-xs text-slate-mid">Unassigned</div>
          </div>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-dark" role="img" aria-label="Budget progress: 77% assigned">
          <div class="flex h-full">
            <div class="h-full bg-emerald transition-all duration-1000" style="width: 77%;"></div>
            <div class="h-full bg-gold transition-all duration-1000" style="width: 15%;"></div>
          </div>
        </div>
        <div class="mt-3 grid grid-cols-3 gap-2 text-left text-xs">
          <div class="rounded-lg bg-slate-dark/40 px-2 py-1.5">
            <div class="text-slate-mid">Rent</div>
            <div class="font-mono font-semibold text-white">&pound;800</div>
          </div>
          <div class="rounded-lg bg-slate-dark/40 px-2 py-1.5">
            <div class="text-slate-mid">Groceries</div>
            <div class="font-mono font-semibold text-white">&pound;300</div>
          </div>
          <div class="rounded-lg bg-slate-dark/40 px-2 py-1.5">
            <div class="text-slate-mid">Hobbies</div>
            <div class="font-mono font-semibold text-emerald">&pound;150</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
