---
const PRE_LAUNCH = true

const plans = [
  {
    name: 'Community',
    price: 'Free',
    period: 'forever',
    description: 'Full-featured budgeting for individuals. Self-host or use our cloud.',
    features: [
      'Zero-sum budgeting',
      'Double-entry bookkeeping',
      'Unlimited nested pots',
      'Key:value label system',
      'Clearing house',
      'Spreadsheet-speed UI',
      'Multi-currency support',
      'Self-hostable on your infrastructure'
    ],
    cta: 'Get Started',
    highlight: false,
    accent: 'emerald'
  },
  {
    name: 'Pro',
    price: '\u00A36',
    period: '/month',
    description: 'Automation and intelligence for serious budgeters.',
    features: [
      'Everything in Community',
      'Direct bank sync via OpenBanking',
      'AI receipt parsing',
      'AI auto-clearing',
      'Priority support',
      'Self-hosted license key available'
    ],
    cta: 'Start Pro Trial',
    highlight: true,
    accent: 'gold'
  },
  {
    name: 'Team',
    price: '\u00A310',
    period: '/month',
    description: 'Shared budgets for couples, housemates, and small teams.',
    features: [
      'Everything in Pro',
      'Shared pots and budgets',
      'Project budgeting',
      'Multi-user access controls',
      'Collaborative clearing house',
      'Team audit log'
    ],
    cta: 'Start Team Trial',
    highlight: false,
    accent: 'violet'
  }
]
---

<section id="pricing" class="border-t border-slate-dark/50 py-20 md:py-28" aria-labelledby="pricing-heading">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center" data-reveal>
      <h2 id="pricing-heading" class="mb-4 font-serif text-3xl font-bold text-white md:text-4xl">Simple, honest pricing</h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-light">
        The core is free and open-source. Pay only for premium automation and team features.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3" data-stagger data-reveal>
      {plans.map(plan => (
        <div class:list={[
          'hover-lift relative flex flex-col rounded-2xl border p-8',
          plan.highlight
            ? 'border-gold/30 bg-gradient-to-b from-gold/5 to-transparent'
            : 'border-slate-dark/50 bg-deep-navy/50'
        ]}>
          {plan.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gold px-4 py-1 text-xs font-bold text-midnight">
              Recommended
            </div>
          )}
          <div class="mb-6">
            <h3 class="mb-1 text-lg font-semibold text-white">{plan.name}</h3>
            <p class="text-sm text-slate-light">{plan.description}</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-extrabold text-white">{plan.price}</span>
            {plan.period !== 'forever' && (
              <span class="text-slate-mid">{plan.period}</span>
            )}
          </div>
          <ul class="mb-8 flex-1 space-y-3">
            {plan.features.map(feature => (
              <li class="flex items-start gap-2 text-sm text-slate-light">
                <span class:list={[
                  'mt-0.5',
                  plan.accent === 'gold' ? 'text-gold' : plan.accent === 'violet' ? 'text-violet' : 'text-emerald'
                ]} aria-hidden="true">&#x2713;</span>
                {feature}
              </li>
            ))}
          </ul>
          {PRE_LAUNCH ? (
            <a
              href="#notify"
              class:list={[
                'block rounded-lg py-3 text-center text-sm font-semibold transition-all',
                plan.highlight
                  ? 'bg-gold text-midnight hover:bg-gold-light hover:shadow-lg hover:shadow-gold/20'
                  : 'border border-slate-dark text-white hover:border-slate-mid hover:bg-deep-navy'
              ]}
            >
              Get Notified
            </a>
          ) : (
            <a
              href="#"
              class:list={[
                'block rounded-lg py-3 text-center text-sm font-semibold transition-all',
                plan.highlight
                  ? 'bg-gold text-midnight hover:bg-gold-light hover:shadow-lg hover:shadow-gold/20'
                  : 'border border-slate-dark text-white hover:border-slate-mid hover:bg-deep-navy'
              ]}
            >
              {plan.cta}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
